SELECT * FROM Production.Products;
SELECT * FROM Production.Categories;

ALTER TABLE Producion.Products WITH CHECK 
ADD CONSTRAINT FK_Products_CatID FOREIGN KEY (CatID)
REFERENCES Production.Categories (CatID);
GO
